generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                         String    @id @default(cuid())
  email                      String    @unique
  passwordHash               String
  firstName                  String?
  lastName                   String?
  phone                      String?
  emailVerifiedAt            DateTime?
  emailVerificationToken     String?   @unique
  emailVerificationExpiresAt DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  policies                   Policy[]
}

model Policy {
  id              String                 @id @default(cuid())
  userId          String?
  user            User?                  @relation(fields: [userId], references: [id])
  email           String
  orderId         Int
  orderHash       String
  offerId         Int
  policyId        Int
  productType     String
  policyNumber    String?
  vendorName      String?
  premium         Float?
  currency        String                 @default("RON")
  startDate       String?
  endDate         String?
  vehicleVin      String?
  vehiclePlate    String?
  vehicleCategory String?
  ownerCnpHash    String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime               @default(now())
  expiryReminders PolicyExpiryReminder[]

  @@index([userId])
  @@index([email])
}

model ReminderSettings {
  id                    String   @id @default("default")
  reminderDayOffsets    String   @default("30,7,1")
  remindersEnabled      Boolean  @default(true)
  emailRemindersEnabled Boolean  @default(true)
  smsRemindersEnabled   Boolean  @default(true)
  updatedAt             DateTime @updatedAt
  updatedByEmail        String?
}

model PolicyExpiryReminder {
  id           String   @id @default(cuid())
  policyDbId   String
  policy       Policy   @relation(fields: [policyDbId], references: [id], onDelete: Cascade)
  reminderDays Int
  channel      String
  recipient    String
  success      Boolean  @default(false)
  errorMessage String?
  sentAt       DateTime @default(now())

  @@unique([policyDbId, reminderDays, channel])
  @@index([sentAt])
  @@index([policyDbId])
}

model CheckoutSession {
  id           String   @id @default(cuid())
  token        String   @unique
  orderId      Int
  offerId      Int
  orderHash    String
  productType  String
  email        String?
  padOfferId   Int?
  policyData   String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([token])
  @@index([orderHash])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  productType String?
  orderId     Int?
  orderHash   String?
  offerId     Int?
  policyId    Int?
  email       String?
  ipAddress   String?
  userAgent   String?
  payload     String?
  pdfHash     String?
  createdAt   DateTime @default(now())

  @@index([orderHash])
  @@index([email])
  @@index([ipAddress])
  @@index([policyId])
}

