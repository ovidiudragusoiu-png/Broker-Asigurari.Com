SEC_CIK_CELH=0001341766
SEC_CIK_SOFI=0001818874
SEC_CIK_TTD=0001671933
SEC_CIK_META=0001326801
SEC_CIK_HNST=0001530979
SEC_CIK_CHGG=0001364954
SEC_CIK_FUBO=0001484769

# Set this if you want buy/add recommendations to include deployable cash.
CASH_AVAILABLE_USD=

# SMTP email delivery
