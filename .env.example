INSURETECH_API_URL=https://api.example.com
INSURETECH_USERNAME=your-username
INSURETECH_PASSWORD=your-password
INSURETECH_API_KEY=your-api-key
INSURETECH_REQUEST_TIMEOUT_MS=15000

# Portfolio News Advisor
# Leave blank to disable a provider. The automation continues with available data.
