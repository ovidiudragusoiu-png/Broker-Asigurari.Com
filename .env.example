INSURETECH_API_URL=https://api.example.com
INSURETECH_USERNAME=your-username
INSURETECH_PASSWORD=your-password
INSURETECH_API_KEY=your-api-key
INSURETECH_REQUEST_TIMEOUT_MS=15000

# Google Ads weekly performance report automation
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
GOOGLE_ADS_CLIENT_ID=your-google-oauth-client-id
GOOGLE_ADS_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-google-ads-refresh-token
GOOGLE_ADS_REPORT_CONFIG_PATH=config/google-ads-weekly-report.config.json

# Optional: override config.loginCustomerId when using an MCC account.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# AI recommendation layer
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-5

# Email delivery for weekly reports
RESEND_API_KEY=your-resend-api-key
