# Optional: Google Search Console HTML tag verification (meta tag content value only)
# GOOGLE_SITE_VERIFICATION=

# Public site URL for auth emails and redirects (http://localhost:3000 in local dev)
# NEXT_PUBLIC_SITE_URL=https://www.sigur.ai

# Comma-separated admin emails (access /admin dashboard)
# ADMIN_EMAILS=office@sigur.ai,ovidiu.dragusoiu@gmail.com

# Daily cron auth (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
# CRON_SECRET=generate-a-long-random-string

# Optional SMS via Twilio (https://www.twilio.com) — skipped if unset
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+15005550006

INSURETECH_API_URL=https://api.example.com
INSURETECH_USERNAME=your-username
INSURETECH_PASSWORD=your-password
INSURETECH_API_KEY=your-api-key
INSURETECH_REQUEST_TIMEOUT_MS=15000
