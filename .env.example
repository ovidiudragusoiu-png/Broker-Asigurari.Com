INSURETECH_API_URL=https://api.example.com
INSURETECH_USERNAME=your-username
INSURETECH_PASSWORD=your-password
INSURETECH_API_KEY=your-api-key
INSURETECH_REQUEST_TIMEOUT_MS=15000

# Weekly Google Ads performance reporting
GOOGLE_ADS_CLIENT_ID=your-google-oauth-client-id
GOOGLE_ADS_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
GOOGLE_ADS_REFRESH_TOKEN=your-google-oauth-refresh-token
GOOGLE_ADS_LOGIN_CUSTOMER_ID=optional-manager-account-id-without-dashes
GOOGLE_ADS_API_VERSION=v22
GOOGLE_ADS_REPORT_CONFIG_PATH=config/google-ads-weekly-report.json
GOOGLE_ADS_CUSTOMER_ID=optional-customer-id-if-no-config-file
GOOGLE_ADS_CAMPAIGN_IDS=optional-comma-separated-campaign-ids
GOOGLE_ADS_REPORT_EMAIL_TO=marketing@example.com
GOOGLE_ADS_REPORT_EMAIL_FROM=Google Ads Reports <reports@example.com>

# Optional AI recommendation layer. If unset, deterministic recommendations are used.
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_ADS_AI_MODEL=claude-sonnet-4-5

# Email delivery via Resend.
RESEND_API_KEY=your-resend-api-key

# Optional protection for the scheduled API endpoint.
GOOGLE_ADS_REPORT_CRON_SECRET=change-me
